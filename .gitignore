# Python
__pycache__/
*.pyc
venv/

# Artist assets (backed up separately)
artists/*/assets/

# Artist snapshots
artists/*/.snapshots/

# Runtime data
data/
logs/
artists/*/analytics.json
artists/*/analytics.json.bak
artists/*/data.db
artists/*/data.db-shm
artists/*/data.db-wal
_claude_sessions.json
_vibe_sessions/
# aider session files (per-artist, regenerated on each session)
artists/*/.aider.chat.history.md
artists/*/.aider.input.history
artists/*/.adze-context.md
*.pid

# Secrets
artists/*/.env
.env

# External (remote Seed) artists — per-deployment SSH key + manifest cache
artists/*/ssh_key
artists/*/ssh_key.pub
artists/*/.adze-remote.cache.json

# Compiled output
output/

# Temp files
*.tmp
.DS_Store
